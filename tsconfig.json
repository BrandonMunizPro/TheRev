{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node", "jest"],
    "lib": ["ES2020"],
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/index.ts", "src/data-source.ts", "src/resolvers/**/*.ts", "src/entities/**/*.ts", "src/services/**/*.ts", "src/models/**/*.ts", "src/auth/**/*.ts", "src/graphql/**/*.ts", "src/ai/**/*.ts", "src/dao/**/*.ts", "src/database/**/*.ts", "src/migrations/**/*.ts", "src/errors/**/*.ts", "src/cache/redis/AITaskQueueManager.ts"],
  "exclude": ["node_modules", "dist", "src/electron", "src/tests", "src/browser", "src/cache/redis/RedisClusterManager.ts"]
}
