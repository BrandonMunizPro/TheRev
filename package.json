{
  "name": "therev",
  "version": "1.0.0",
  "description": "Forum Political topics and where you can have your own profile",
  "main": "index.js",
  "scripts": {
    "start": "npm run build && node dist/index.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "build:start": "npm run build && node dist/index.js",
    "electron": "electron src/electron/main.cjs",
    "electron:full": "concurrently \"npm run start:dev\" \"npm run electron\"",
    "electron:full:dev": "concurrently \"npm run start:dev\" \"node src/browser/automation-server.cjs\" \"npm run electron\"",
    "browser:automation": "node src/browser/automation-server.cjs",
    "build:electron": "echo 'Electron uses CommonJS files - no build needed'",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./src/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "test": "jest --testPathPatterns=tests --testPathIgnorePatterns=integration",
    "test:watch": "jest --testPathPatterns=tests --testPathIgnorePatterns=integration --watch",
    "test:coverage": "jest --testPathPatterns=tests --testPathIgnorePatterns=integration --coverage",
    "test:coverage:check": "jest --testPathPatterns=tests --testPathIgnorePatterns=integration --coverage --passWithNoTests",
    "test:ci": "jest --testPathPatterns=tests --testPathIgnorePatterns=integration --ci --coverage --watchAll=false",
    "test:unit": "jest --testPathPatterns=tests --testPathIgnorePatterns=integration",
    "test:integration:docker": "NODE_OPTIONS='--experimental-vm-modules' NODE_ENV=test INTEGRATION_TESTS=true jest --testPathPatterns=integration --verbose --detectOpenHandles --forceExit --passWithNoTests",
    "docker:build": "docker build -t therev-app .",
    "docker:build:test": "docker build -f Dockerfile.test -t therev-test .",
    "docker:up": "docker-compose -f docker-compose.infra.yml up -d",
    "docker:down": "docker-compose -f docker-compose.infra.yml down",
    "docker:status": "docker-compose -f docker-compose.infra.yml ps",
    "docker:logs": "docker-compose logs -f",
    "docker:test": "powershell -ExecutionPolicy Bypass -File scripts/docker-integration-test.ps1",
    "validate:docker": "bash scripts/validate-docker-enforcement.sh",
    "check:coverage": "bash scripts/check-coverage.sh",
    "test:docker": "bash scripts/test-docker.sh",
    "docker:dev": "docker-compose up app",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "worker": "npx ts-node src/worker.ts",
    "worker:start": "npm run worker",
    "dev": "npm run docker:up && npm run electron:full",
    "dev:wait": "node scripts/wait-for-db.js && npm run electron:full"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.8.0",
    "@types/ioredis": "^4.28.10",
    "bcrypt": "^6.0.0",
    "class-validator": "^0.14.3",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.0.5",
    "graphql": "^16.12.0",
    "graphql-yoga": "^3.9.1",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.11",
    "openai": "^4.47.0",
    "pg": "^8.16.3",
    "playwright": "^1.42.0",
    "puppeteer": "^22.8.0",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "^2.0.0-rc.2",
    "typeorm": "^0.3.27",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "concurrently": "^9.2.1",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
